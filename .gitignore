# --- Python 通用忽略 ---
# 字节码文件
__pycache__/
*.py[cod]
*$py.class

# 虚拟环境 (venv, venv3, env 等)
venv/
env/
ENV/
.venv/

# 依赖包管理
requirements.txt
Pipfile.lock
*.egg-info/
dist/
build/

# IDE 配置 (PyCharm, VS Code 等)
.idea/
.vscode/
*.iml
*.swp
*.swo
*~

# 操作系统文件
.DS_Store
Thumbs.db

# --- 项目特定敏感信息忽略 (重要) ---
# 避免硬编码的账号密码、Cookies、Token 泄露
.env
.env.local
*.key
*.pem
secrets.json
config_private.py

# 如果打算将敏感配置单独存放，建议忽略此类文件
auth_info.py
cookies_backup.txt
