//获取 修改属性
Object.defineProperty(p1,p2)
p1:需要定义的当前对象  p2:需要定义的属性名
user = {'age',12}
aa= user.age
Object.defineProperty(user,'age',{
    get:function(){
        return aa;
    }
    set:function(new_data){
        aa = new_data
        return new_data;
    }
})
}

//hook cookie  应对 cookie加密     document.cookie  hook的时候需要把cookie 清空
(function () {
    cookie_data = document.cookie;
    Object.defineProperty(document, 'cookie',
        {
            set: function (val) {
                if (val.indexOf('v') != -1) {
                    debugger
                }
                cookie_data = val
            },
            get: function () {
                return cookie_data
            }
        })
})()

