hook 方法
var _parse = JSON.parse
_parse() 就跟 json.parse 是一样的效果
JSON.parse = function(){console.log('我被hook了')}
表单数据 经常调用json.parse 除非直接传数组    载荷数据经常JSON.stringify
控制台中重写一下方法 就可以打断点了
var _parse = JSON.parse
JSON.parse = function(params){
    debugger
    return _parse(params)
}
//************ 自执行方法 ************
(function(){
var _parse = JSON.parse
JSON.parse = function(params){
    debugger
    return _parse(params)
})();
